MQTT_URL=mqtt://localhost:1883
MQTT_TOPIC=nirwana/telemetry
BACKEND_PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
# Lokasi file cache riwayat (opsional). Default: server/data/history.json
HISTORY_FILE=

# AI Insight (NVIDIA NIM, https://build.nvidia.com) — opsional.
# Kosongkan NVIDIA_API_KEY untuk menonaktifkan fitur AI Insight.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
INSIGHT_INTERVAL_MS=45000

NEXT_PUBLIC_TELEMETRY_API=http://localhost:4000
NEXT_PUBLIC_MQTT_TOPIC=nirwana/telemetry

# Identitas pasien & klinisi (opsional, ada nilai default di lib/profile.js)
NEXT_PUBLIC_PATIENT_NAME=Ananda Putra
NEXT_PUBLIC_PATIENT_CODE=Neo-0824-A
NEXT_PUBLIC_PATIENT_SUBJECT=Neonatus-01
NEXT_PUBLIC_MONITOR_ID=NW-2024-001
NEXT_PUBLIC_CLINICIAN_NAME=Dr. Arisandi
